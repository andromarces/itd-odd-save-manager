{
  "name": "itd-odd-save-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "format": "npm run format:oxfmt && npm run format:rust",
    "format:check": "npm run format:oxfmt:check && npm run format:rust:check",
    "format:oxfmt": "node ./scripts/run-oxfmt-tracked.mjs",
    "format:oxfmt:check": "node ./scripts/run-oxfmt-tracked.mjs --check",
    "format:rust": "cd src-tauri && cargo fmt",
    "format:rust:check": "cd src-tauri && cargo fmt --all -- --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "!(*.rs)": "node ./scripts/run-oxfmt-tracked.mjs",
    "**/*.rs": "rustfmt --edition 2021"
  }
}
