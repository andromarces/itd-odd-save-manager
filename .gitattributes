# Keep tracked text files on LF across platforms so oxfmt sees stable input in CI.
# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted to LF on checkout.
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
.* text eol=lf
