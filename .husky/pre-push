if git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" > /dev/null 2>&1; then
  base="@{upstream}"
else
  # No upstream configured. Find the fork point against the remote default branch
  # so only the branch's own commits are linted, not the full repo history.
  base=""
  for candidate in origin/main origin/master; do
    if git rev-parse --verify "$candidate" > /dev/null 2>&1; then
      base=$(git merge-base HEAD "$candidate")
      break
    fi
  done
  if [ -z "$base" ]; then
    echo "No upstream and no remote default branch found. Skipping pre-push lint."
    exit 0
  fi
fi

# Lint changed JS/TS files since the upstream base.
npx lint-staged --config .lintstagedrc.push.json --diff="${base}...HEAD"

# Run cargo clippy in src-tauri only when Rust files changed since the base.
if git diff --name-only "${base}...HEAD" | grep -q '\.rs$'; then
  echo "Rust files changed since ${base}. Running cargo clippy in src-tauri/..."
  (cd src-tauri && cargo clippy -- -D warnings)
fi
